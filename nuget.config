<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local dev feed (dotnet pack from granit-dotnet) -->
    <!-- <add key="local" value="/home/jf/granit-local-feed" />-->
    <!-- GitHub Package Registry (Granit packages) -->
    <add key="granit-registry" value="https://nuget.pkg.github.com/granit-fx/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <!--<packageSource key="local">
      <package pattern="Granit" />
      <package pattern="Granit.*" />
    </packageSource>-->
    <packageSource key="granit-registry">
      <package pattern="Granit" />
      <package pattern="Granit.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
